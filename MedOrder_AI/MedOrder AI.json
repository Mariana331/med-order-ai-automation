    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  try {\n    let output = item.json.output;\n    \n    // Очищаємо від escaped символів\n    output = output.replace(/\\\\n/g, '').replace(/\\\\/g, '').trim();\n    \n    // Видаляємо можливі markdown блоки\n    output = output.replace(/```json/g, '').replace(/```/g, '').trim();\n    \n    // Парсимо JSON\n    const data = JSON.parse(output);\n    \n    // Якщо масив - беремо перший елемент\n    const parsed = Array.isArray(data) ? data[0] : data;\n    \n    return {\n      json: {\n        audio_url: parsed.audio_url || null,\n        status: parsed.status || null,\n        tone: parsed.tone || null,\n        category: parsed.category || null,\n        order: parsed.order || null,\n      }\n    };\n    \n  } catch (error) {\n    return {\n      json: {\n        error: 'Parse error: ' + error.message,\n        raw_output: item.json.output\n      }\n    };\n  }\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
